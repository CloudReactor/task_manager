FROM cloudreactor-task-manager

USER root

WORKDIR /tmp

# Install Python dependencies as root before switching to non-root user
# Using export->install instead of sync for better Docker layer caching
COPY server/pyproject.toml server/uv.lock /tmp/
RUN cd /tmp && \
    uv export --frozen --extra dev -o dev-requirements.txt && \
    uv pip install --no-cache -r dev-requirements.txt && \
    rm -rf /tmp/*

USER appuser

ENV UV_SYSTEM_PYTHON=1 \
    UV_IGNORE_DOT_VENV=1

WORKDIR /home/appuser/src

COPY server/.env.test ./

CMD ["pytest"]
